# BikeCare Tracker — Firestore Security Rules
# 
# Copy these rules to your Firebase Console:
# Firebase Console → Firestore Database → Rules → Paste → Publish
#
# Direct link: https://console.firebase.google.com/project/YOUR_PROJECT_ID/firestore/rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection (private — auth required) ─────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // User's sub-collections (bikes, notifications, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Nested sub-collections (maintenanceTasks, documents, etc.)
        match /{nestedCollection}/{nestedDocId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // ── Push Subscriptions (readable by server cron — NO auth needed) ──────
    // This collection stores push subscriptions and notification settings.
    // It is READ by the Vercel cron job using only the Firebase API key.
    // WRITE requires the user to be logged in (only own data).
    match /push_subscriptions/{userId} {
      allow read: if true;    // Public read — needed for cron to send notifications
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}